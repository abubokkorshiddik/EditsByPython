import numpy as np
import matplotlib.pyplot as plt
from PIL import Image, ImageEnhance, ImageFilter, ImageDraw, ImageFont
import cv2
import os

# ─────────────────────────────────────────────
# 1. CONFIGURATION — Edit these to your taste
# ─────────────────────────────────────────────
IMAGE_PATH   = r"C:\Users\Abu Bokkor Shiddik\Downloads\576052137-2ca33777-cbba-4e31-80d5-3016c3fd968f.png"
OUTPUT_PATH  = r"C:\Users\Abu Bokkor Shiddik\Downloads\instagram_pro_output.jpg"
OUTPUT_SIZE  = (1080, 1350)   # Instagram 4:5 portrait (best for feed)
# OUTPUT_SIZE = (1080, 1080)  # Uncomment for square 1:1

WATERMARK_TEXT = "@abs"   # Set "" to skip watermark

# Tuning knobs (1.0 = original)
BRIGHTNESS   = 1.08   # Slight lift
CONTRAST     = 1.18   # Punchier
SATURATION   = 1.25   # Vivid colours
SHARPNESS    = 1.60   # Crispy detail
WARMTH       = 12     # Orange tint (+) or cool tint (-)
VIGNETTE_STR = 0.55   # Vignette intensity 0–1
GLOW_OPACITY = 0.18   # Soft glow/bloom 0–1
SHADOW_LIFT  = 15     # Lift shadows (0 = no change)
HIGHLIGHT_CL = 240    # Clip highlights below 255 (235–250 typical)


# ─────────────────────────────────────────────
# 2. LOAD IMAGE
# ─────────────────────────────────────────────
def load_image(path: str) -> Image.Image:
    img = Image.open(path).convert("RGB")
    print(f"")
    return img


# ─────────────────────────────────────────────
# 3. INSTAGRAM CROP  (smart centre-crop)
# ─────────────────────────────────────────────
def smart_crop(img: Image.Image, target: tuple) -> Image.Image:
    tw, th = target
    iw, ih = img.size
    scale  = max(tw / iw, th / ih)
    new_w, new_h = int(iw * scale), int(ih * scale)
    img = img.resize((new_w, new_h), Image.LANCZOS)
    left = (new_w - tw) // 2
    top  = (new_h - th) // 2
    img  = img.crop((left, top, left + tw, top + th))
    print(f"")
    return img


# ─────────────────────────────────────────────
# 4. BASIC ENHANCEMENTS
# ─────────────────────────────────────────────
def basic_enhance(img: Image.Image) -> Image.Image:
    img = ImageEnhance.Brightness(img).enhance(BRIGHTNESS)
    img = ImageEnhance.Contrast(img).enhance(CONTRAST)
    img = ImageEnhance.Color(img).enhance(SATURATION)
    img = ImageEnhance.Sharpness(img).enhance(SHARPNESS)
    print("")
    return img


# ─────────────────────────────────────────────
# 5. CINEMATIC COLOR GRADE
#    S-curve + shadow lift + highlight clip
# ─────────────────────────────────────────────
def build_scurve_lut(shadow_lift: int = 0, highlight_clip: int = 255) -> np.ndarray:
    """Smooth S-curve lookup table (0–255)."""
    x = np.arange(256, dtype=np.float32)
    # normalise
    x_n = x / 255.0
    # gentle S-curve via sine
    y   = 0.5 * (1 + np.sin(np.pi * (x_n - 0.5)))
    # shadow lift
    y   = y * (1 - shadow_lift / 255.0) + shadow_lift / 255.0
    # highlight clip
    y   = np.clip(y * (highlight_clip / 255.0), 0, 1)
    return (y * 255).astype(np.uint8)


def color_grade(img: Image.Image) -> Image.Image:
    arr  = np.array(img, dtype=np.float32)
    lut  = build_scurve_lut(SHADOW_LIFT, HIGHLIGHT_CL)

    # Apply S-curve per channel
    arr_u8 = np.clip(arr, 0, 255).astype(np.uint8)
    graded = lut[arr_u8]

    # Warmth shift: boost R, lower B
    graded = graded.astype(np.float32)
    graded[:, :, 0] = np.clip(graded[:, :, 0] + WARMTH, 0, 255)   # R
    graded[:, :, 2] = np.clip(graded[:, :, 2] - WARMTH * 0.6, 0, 255)  # B

    img = Image.fromarray(graded.astype(np.uint8))
    print("")
    return img


# ─────────────────────────────────────────────
# 6. VIGNETTE
# ─────────────────────────────────────────────
def add_vignette(img: Image.Image, strength: float = 0.5) -> Image.Image:
    w, h = img.size
    arr  = np.array(img, dtype=np.float32)

    # Radial gradient (0 = centre, 1 = corner)
    X = np.linspace(-1, 1, w)
    Y = np.linspace(-1, 1, h)
    xx, yy = np.meshgrid(X, Y)
    radius = np.sqrt(xx**2 + yy**2)
    radius = radius / radius.max()

    # Smooth falloff
    mask = 1 - np.clip(radius * strength * 1.4, 0, 1) ** 1.8
    mask = mask[:, :, np.newaxis]

    arr = arr * mask
    img = Image.fromarray(np.clip(arr, 0, 255).astype(np.uint8))
    
    return img


# ─────────────────────────────────────────────
# 7. SOFT GLOW / BLOOM
# ─────────────────────────────────────────────
def add_glow(img: Image.Image, opacity: float = 0.15) -> Image.Image:
    blurred = img.filter(ImageFilter.GaussianBlur(radius=14))
    img = Image.blend(img, blurred, alpha=opacity)
   
    return img


# ─────────────────────────────────────────────
# 8. SHARPENING PASS  (unsharp mask)
# ─────────────────────────────────────────────
def final_sharpen(img: Image.Image) -> Image.Image:
    img = img.filter(ImageFilter.UnsharpMask(radius=1.5, percent=130, threshold=3))
    
    return img


# ─────────────────────────────────────────────
# 9. WATERMARK
# ─────────────────────────────────────────────
def add_watermark(img: Image.Image, text: str) -> Image.Image:
    if not text:
        return img
    draw    = ImageDraw.Draw(img)
    w, h    = img.size
    font_sz = max(30, w // 28)

    # Try to load a system font, fall back to default
    try:
        font = ImageFont.truetype("arial.ttf", font_sz)
    except Exception:
        try:
            font = ImageFont.truetype("/usr/share/fonts/truetype/dejavu/DejaVuSans-Bold.ttf", font_sz)
        except Exception:
            font = ImageFont.load_default()

    # Measure text
    bbox = draw.textbbox((0, 0), text, font=font)
    tw, th = bbox[2] - bbox[0], bbox[3] - bbox[1]
    margin = int(h * 0.035)
    x = w - tw - margin
    y = h - th - margin

    # Shadow
    draw.text((x + 2, y + 2), text, font=font, fill=(0, 0, 0, 160))
    # White text
    draw.text((x, y), text, font=font, fill=(255, 255, 255, 220))
    print(f" ")
    return img


# ─────────────────────────────────────────────
# 10. PREVIEW & SAVE
# ─────────────────────────────────────────────
def preview_and_save(original: Image.Image, final: Image.Image, out_path: str):
    fig, axes = plt.subplots(1, 2, figsize=(16, 9))
    fig.patch.set_facecolor("#111111")

    for ax, im, title in zip(axes, [original, final], ["ORIGINAL", "EDIT"]):
        ax.imshow(im)
        ax.set_title(title, color="white", fontsize=14, fontweight="bold", pad=10)
        ax.axis("off")

    plt.suptitle("", color="white", fontsize=18, fontweight="bold", y=1.01)
    plt.tight_layout()
    plt.show()

    # Save as high-quality JPEG
    final.save(out_path, "JPEG", quality=97, optimize=True, progressive=True)
    size_kb = os.path.getsize(out_path) / 1024
    print(f"\n🎉 Saved!   │ {out_path}")
    print(f"   File size │ {size_kb:.1f} KB")


# ─────────────────────────────────────────────
# 11. MAIN PIPELINE
# ─────────────────────────────────────────────
def main():
    print("\n" + "═" * 52)
    
    print("═" * 52 + "\n")

    original = load_image(IMAGE_PATH)

    img = smart_crop(original.copy(), OUTPUT_SIZE)
    img = basic_enhance(img)
    img = color_grade(img)
    img = add_vignette(img, VIGNETTE_STR)
    img = add_glow(img, GLOW_OPACITY)
    img = final_sharpen(img)
    img = add_watermark(img, WATERMARK_TEXT)

    print("\n" + "─" * 52)
    preview_and_save(original, img, OUTPUT_PATH)
    print("─" * 52 + "\n")


if __name__ == "__main__":
    main()


