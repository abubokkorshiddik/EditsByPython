# Radial mask — sharp in centre, fades to cloud at edges
arr  = np.array(sharp, dtype=np.float32)
X    = np.linspace(-1, 1, W); Y = np.linspace(-1, 1, H)
xx, yy = np.meshgrid(X, Y)
dist = np.sqrt((xx/0.58)**2 + (yy/0.88)**2)
fade = np.clip(1 - (dist - 0.50) / 0.50, 0, 1) ** 2.0
arr[:,:,3] = (fade * 255).astype(np.uint8)
sharp_masked = Image.fromarray(arr.astype(np.uint8))
canvas = Image.alpha_composite(canvas, sharp_masked)
print("")

