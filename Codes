fhdl = load_font(44, bold=True)

WHITE  = (255, 255, 255, 255)
SILVER = (220, 218, 230, 215)
GOLD   = (212, 175,  55, 255)

def ctext(text, font, y, col, shadow=True):
    bb = draw.textbbox((0,0), text, font=font)
    tw = bb[2]-bb[0]; th = bb[3]-bb[1]
    x  = (W - tw) // 2
    if shadow:
        for ox,oy in [(3,3),(2,2),(1,1)]:
            draw.text((x+ox,y+oy), text, font=font, fill=(0,0,0,140))
    draw.text((x,y), text, font=font, fill=col)
    return th

yt  = int(H * .836)
yt += ctext(QUOTE1, fq1, yt, WHITE)  + 14
yt += ctext(QUOTE2, fq2, yt, SILVER) + 16
ctext(TAGLINE, ftag, yt, GOLD, shadow=False)

